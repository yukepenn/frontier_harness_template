name: frontier-automerge

on:
  - workflow_dispatch

jobs:
  policy-preview:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - name: Preview merge gate
        run: |
          python tools/frontier/merge_gate.py --dry-run
          echo "Real merge requires lane policy, CI success, verdict success, artifact policy, branch protection, and gh auth. Red requires FRONTIER_RED_AUTHORIZED=1."
