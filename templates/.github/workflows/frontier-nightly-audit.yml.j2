name: frontier-nightly-audit

on:
  schedule:
    - cron: "17 7 * * *"
  workflow_dispatch:

jobs:
  audit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - name: Nightly Frontier audit
        run: |
          python tools/verify.py --boundaries
          python tools/verify.py --artifacts
