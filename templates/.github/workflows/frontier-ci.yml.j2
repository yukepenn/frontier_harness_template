name: frontier-ci

on:
  - push
  - pull_request

jobs:
  validate:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.11"
      - name: Basic harness checks
        run: |
          test -f AGENTS.md
          test -f CLAUDE.md
          test -f frontier.yaml
          python tools/verify.py --ci
